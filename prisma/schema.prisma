// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // Enable PostgreSQL extensions preview feature
}

datasource db {
  provider = "postgresql"
}

// Define your data models here and run `prisma db push` to apply them to the database
// USER - MOVIE - WATCHLIST
model User {
  id        String      @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Relations
  watchlist WatchlistItem[]
  movies Movie[] @relation("MovieCreator")
}

model Movie {
  id          String      @id @default(uuid())
  title       String
  overview    String?
  releaseYear Int
  genre       String[] @default([])
  runtime     Int?
  posterUrl String?
  createdBy   String
  createdAt   DateTime @default(now())

  // Relations
  watchlist WatchlistItem[]
  creator User @relation("MovieCreator", fields: [createdBy], references: [id], onDelete: Cascade)
}

model WatchlistItem {
  id      String      @id @default(uuid())
  userId  String
  movieId String
  status  WatchlistStatus @default(TO_WATCH)
  rating  Int?
  notes   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

enum WatchlistStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
  TO_WATCH
}
